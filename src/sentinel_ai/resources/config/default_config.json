{
  "_metadata": {
    "module_id": "CFG-003",
    "file_id": "CFG-003-001",
    "module_name": "Default Configuration Resource",
    "version": "0.7.0",
    "purpose": "Provides packaged default Sentinel AI configuration values, including symbol management, one-second refresh, and market structure engine settings.",
    "change_history": [
      "0.1.0: Added packaged defaults for Sprint 1 foundation.",
      "0.2.0: Added MT5 connection defaults.",
      "0.3.0: Added market data feed defaults and application version update.",
      "0.4.0: Added live chart rendering resource defaults and application version update.",
      "0.5.0: Added live market refresh defaults and application version update.",
      "0.5.1: Changed supported timeframe refresh defaults to one second for tighter MT5 synchronization.",
      "0.6.0: Added symbol management defaults for broker/account-specific symbol resolution and selection.",
      "0.7.0: Added market structure engine defaults and application version update."
    ]
  },
  "application": {
    "name": "Sentinel AI",
    "version": "0.7.0",
    "environment": "production"
  },
  "trading": {
    "symbol": "GOLDm#",
    "default_timeframe": "M5",
    "auto_trade_enabled": false,
    "one_trade_at_a_time": true,
    "minimum_confidence": 75.0,
    "default_risk_reward": 2.0
  },
  "database": {
    "filename": "sentinel_ai.sqlite3"
  },
  "logging": {
    "filename": "sentinel_ai.log",
    "level": "INFO"
  },
  "ui": {
    "theme": "dark_neon",
    "welcome_required": true,
    "default_width": 1366,
    "default_height": 820
  },
  "mt5": {
    "startup_connect": true,
    "terminal_path": null,
    "default_bar_count": 300,
    "max_bars_per_request": 5000,
    "require_visible_symbol": true
  },
  "market_data": {
    "startup_load": true,
    "default_feed_bar_count": 300,
    "max_chart_candles": 1000,
    "auto_refresh_enabled": true,
    "refresh_intervals_seconds": {
      "M1": 1,
      "M5": 1,
      "M15": 1,
      "M30": 1,
      "H1": 1,
      "H4": 1,
      "D1": 1,
      "DEFAULT": 1
    }
  },
  "symbol_management": {
    "auto_resolve_enabled": true,
    "preferred_aliases": [
      "GOLDm#",
      "XAUUSD",
      "GOLD",
      "XAUUSDm",
      "XAUUSD#",
      "GOLDm",
      "GOLDmicro"
    ],
    "toolbar_max_symbols": 5000
  },
  "analysis": {
    "market_structure": {
      "enabled": true,
      "lookback_candles": 200,
      "swing_window": 2,
      "minimum_swing_distance_price": 0.0,
      "max_chart_markers": 80
    }
  }
}
